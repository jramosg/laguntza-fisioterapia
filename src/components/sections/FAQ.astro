---
import Container from '@components/core/Container.astro';
import { getLangFromUrl } from '@i18n/utils';
import { getFaq } from '@config/faq';

const lang = getLangFromUrl(Astro.url);
const items = getFaq(lang);
const title = lang === 'eu' ? 'Ohiko galderak' : 'Preguntas frecuentes';
---

<section class="faq" aria-labelledby="faq-title">
	<Container narrow>
		<h2 id="faq-title" class="faq__title">{title}</h2>
		<div class="faq__list">
			{
				items.map(({ q, a }) => (
					<details class="faq__item">
						<summary class="faq__q">
							<span>{q}</span>
							<svg
								class="faq__icon"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="m6 9 6 6 6-6" />
							</svg>
						</summary>
						<p class="faq__a">{a}</p>
					</details>
				))
			}
		</div>
	</Container>
</section>

<style>
	.faq {
		padding: var(--s9) 0;
	}
	.faq__title {
		font-size: var(--font-size-xl);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin: 0 0 var(--s6);
	}
	.faq__list {
		display: flex;
		flex-direction: column;
		gap: var(--s3);
	}
	.faq__item {
		border: 1px solid var(--theme-outline, rgba(0, 0, 0, 0.12));
		border-radius: var(--theme-shape-radius, 1rem);
		background: var(--theme-bg);
		transition:
			border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
			background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.faq__item[open] {
		border-color: var(--theme-primary);
		background: var(--theme-surface-1, #f2f2f2);
	}
	.faq__q {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--s4);
		padding: var(--s4) var(--s5);
		min-height: 44px;
		font-size: var(--font-size-base);
		font-weight: 600;
		cursor: pointer;
		list-style: none;
	}
	.faq__q::-webkit-details-marker {
		display: none;
	}
	.faq__icon {
		flex-shrink: 0;
		color: var(--theme-primary);
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.faq__item[open] .faq__icon {
		transform: rotate(180deg);
	}
	.faq__a {
		margin: 0;
		padding: 0 var(--s5) var(--s5);
		font-size: var(--font-size-base);
		line-height: 1.6;
	}
	.faq__q:focus-visible {
		outline: 2px solid var(--theme-primary);
		outline-offset: 2px;
		border-radius: var(--theme-shape-radius, 1rem);
	}
	@media (prefers-reduced-motion: reduce) {
		.faq__item,
		.faq__icon {
			transition: none;
		}
	}
</style>
