---
import Container from './core/Container.astro';
const { id, class: className, ...rest } = Astro.props;
---

<section id={id} class="hero-header-section">
	<div class="hero-header-glow" aria-hidden="true"></div>
	<Container class=`hero-header-container ${className || ''}` {...rest}>
		<slot name="title" />
		<p><slot name="desc" /></p>
		<div class="chips-container">
			<slot name="chips" />
		</div>
	</Container>
</section>

<style>
	.hero-header-section {
		position: relative;
		overflow: hidden;
		background: linear-gradient(180deg, #060a0c 0%, #0a0e10 60%, #0b1013 100%);
		padding: var(--s9) 0 var(--s8);
		text-align: center;
		color: #fff;
	}

	/* Subtle fractal-noise grain, same texture as the homepage dark stream */
	.hero-header-section::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0.03;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		background-repeat: repeat;
		background-size: 200px;
	}

	.hero-header-glow {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(
				ellipse 60% 80% at 15% 0%,
				rgba(69, 130, 149, 0.22) 0%,
				transparent 60%
			),
			radial-gradient(
				ellipse 50% 70% at 90% 100%,
				rgba(232, 148, 74, 0.1) 0%,
				transparent 60%
			);
	}

	.hero-header-container {
		&:global(.content__container) {
			padding: 0;
		}
		width: 100%;
		position: relative;
		animation: hero-rise 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	.hero-header-container :global(h1) {
		padding: var(--container-padding);
		margin: 0 auto;
		max-width: 22ch;
		color: #fff;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.hero-header-container > p {
		padding: var(--container-padding);
		margin: 0 auto;
		max-width: 64ch;
		color: rgba(255, 255, 255, 0.78);
		line-height: 1.7;
	}

	.hero-header-container :global(.chip) {
		color: var(--theme-on-container-gradient);
		svg {
			fill: var(--theme-on-container-gradient);
		}
	}

	:global(.hero-section__remark) {
		background-image: linear-gradient(
			to right,
			var(--theme-secondary),
			var(--theme-secondary-300, #f2b27e)
		);
		background-clip: text;
		color: transparent;
	}

	.chips-container {
		display: flex;
		justify-content: center;
		gap: var(--s2);
		flex-wrap: wrap;
		padding-top: var(--s4);
	}

	@keyframes hero-rise {
		from {
			opacity: 0;
			transform: translateY(28px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-header-container {
			animation: none;
		}
	}

	@media (max-width: 768px) {
		.chips-container {
			overflow-x: auto;
			flex-wrap: nowrap;
			gap: var(--s2);
			padding-bottom: var(--s2);
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
		}
		.chips-container::-webkit-scrollbar {
			display: none;
		}
		.chips-container > * {
			flex: 0 0 auto;
		}
	}
</style>
