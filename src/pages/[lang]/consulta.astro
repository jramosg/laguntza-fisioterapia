---
import Layout from '@layouts/Page.astro';
import {
	getLangFromUrl,
	getStaticLangPaths,
	useTranslations
} from '@i18n/utils';
import { Langs } from '@i18n/ui';
import Container from '@components/core/Container.astro';
import Consulta3D from '@components/Consulta3D.astro';
import Button from '@components/buttons/Button.astro';
import { Image } from 'astro:assets';
import Rehab from '@images/rehab.webp';
import ConsultaSala from '@images/consulta-sala.jpg';
import ConsultaEspera from '@images/consulta-espera.jpg';
import KristalaFrentez from '@images/kristala-frentez.jpg';
import KristalaLateralez from '@images/kristala-lateralez.jpg';

export function getStaticPaths() {
	return getStaticLangPaths();
}

const lang: Langs = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const seo = {
	title:
		lang === 'eu'
			? 'Kontsulta | Laguntza Fisioterapia Urnieta - Zubitxo Plaza 3, Gipuzkoa'
			: 'La consulta | Laguntza Fisioterapia Urnieta - Zubitxo Plaza 3, Gipuzkoa',
	description:
		lang === 'eu'
			? 'Ezagutu Laguntza Fisioterapiaren kontsulta Urnietan: espazio argitsu eta irisgarria Zubitxo Plazan. Ibili eredu 3Dan etorri aurretik.'
			: 'Conoce la consulta de Laguntza Fisioterapia en Urnieta: un espacio luminoso y accesible en Zubitxo Plaza. Recórrela en 3D antes de venir.',
	keywords:
		lang === 'eu'
			? 'Laguntza Fisioterapia kontsulta, fisioterapia zentroa Urnieta, Zubitxo Plaza 3, instalazioak fisioterapia Gipuzkoa, kontsulta irisgarria'
			: 'Laguntza Fisioterapia consulta, centro fisioterapia Urnieta, Zubitxo Plaza 3, instalaciones fisioterapia Gipuzkoa, consulta accesible',
	breadcrumb: [
		{ name: 'Laguntza Fisioterapia', url: `/${lang}` },
		{
			name: lang === 'eu' ? 'Kontsulta' : 'La consulta',
			url: `/${lang}/consulta`
		}
	]
};
---

<Layout {seo}>
	<Container>
		<section class="consulta">
			<header class="consulta__intro">
				<p class="consulta__eyebrow">
					{lang === 'eu' ? 'GURE TXOKOA' : 'NUESTRO ESPACIO'}
				</p>
				<h1 class="consulta__title">
					{lang === 'eu' ? 'Kontsulta' : 'La consulta'}
				</h1>
				<p class="consulta__lead">
					{
						lang === 'eu'
							? 'Espazio argitsu eta irisgarria Zubitxo Plazan, Urnietan (Gipuzkoa): sarrera, bi gela, komuna eta korridorea, kristalez betetako fatxada batekin soportaletara. Ibili eredu 3Dan etorri aurretik.'
							: 'Un espacio luminoso y accesible en Zubitxo Plaza, Urnieta (Gipuzkoa): entrada, dos salas, baño y pasillo, con una fachada acristalada a los soportales. Recórrelo en 3D antes de venir.'
					}
				</p>
			</header>

			<Consulta3D lang={lang} />

			<figure class="consulta__featured">
				<Image
					src={Rehab}
					alt={lang === 'eu'
						? 'Jokin Ramos paziente bati tratamendua ematen Laguntza Fisioterapiako kontsultan, Urnietan'
						: 'Jokin Ramos tratando a una paciente en la consulta de Laguntza Fisioterapia, Urnieta'}
					widths={[480, 760, 1040]}
					sizes="(max-width: 760px) 100vw, 520px"
					loading="lazy"
				/>
			</figure>

			<div class="consulta__photos">
				<Image
					src={ConsultaSala}
					alt={lang === 'eu'
						? 'Laguntza Fisioterapiaren tratamendu gela, ohatila eta ekografoarekin, Urnietan'
						: 'Sala de tratamiento de Laguntza Fisioterapia con camilla y ecógrafo, Urnieta'}
					widths={[480, 800, 1200]}
					sizes="(max-width: 768px) 100vw, 50vw"
					loading="lazy"
				/>
				<Image
					src={ConsultaEspera}
					class="consulta__photo--tall"
					alt={lang === 'eu'
						? 'Laguntza Fisioterapiaren itxarongela, besaulkiekin eta logotipoarekin, Urnietan'
						: 'Sala de espera de Laguntza Fisioterapia con sillones y el logotipo, Urnieta'}
					widths={[480, 800, 1200]}
					sizes="(max-width: 768px) 100vw, 50vw"
					loading="lazy"
				/>
				<Image
					src={KristalaFrentez}
					alt={lang === 'eu'
						? 'Laguntza Fisioterapiaren fatxada, Zubitxo Plaza, Urnieta'
						: 'Fachada de Laguntza Fisioterapia, Zubitxo Plaza, Urnieta'}
					widths={[480, 800, 1200]}
					sizes="(max-width: 768px) 100vw, 50vw"
					loading="lazy"
				/>
				<Image
					src={KristalaLateralez}
					alt={lang === 'eu'
						? 'Laguntza Fisioterapiaren sarrera soportaletatik'
						: 'Entrada de Laguntza Fisioterapia desde los soportales'}
					widths={[480, 800, 1200]}
					sizes="(max-width: 768px) 100vw, 50vw"
					loading="lazy"
				/>
			</div>

			<div class="consulta__cta">
				<p class="consulta__cta-text">
					{
						lang === 'eu'
							? 'Ezagutu nahi duzu pertsonalki? Hartu hitzordua eta hurbildu.'
							: '¿Quieres conocerla en persona? Pide cita y acércate.'
					}
				</p>
				<Button href={`/${lang}/contact`}>
					{t('Hitzordua hartu')}
				</Button>
			</div>
		</section>
	</Container>
</Layout>

<style>
	.consulta {
		padding-top: calc(var(--header-height, 5.8rem) + var(--s4, 2rem));
		margin-bottom: calc(var(--section-margin, 4rem) * 1.5);
	}
	.consulta__intro {
		max-width: 62ch;
		margin-bottom: var(--s4, 2rem);
	}
	.consulta__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		color: var(--theme-primary, #458295);
	}
	.consulta__title {
		margin: 0 0 0.75rem;
		font-size: var(--font-size-xxl, clamp(2.2rem, 5vw, 3.75rem));
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.08;
	}
	.consulta__lead {
		margin: 0;
		font-size: var(--font-size-lg, 1.15rem);
		line-height: 1.55;
		color: var(--theme-text-secondary, #6f6f70);
	}

	.consulta__featured {
		margin: var(--s3, 1.5rem) auto 0;
		max-width: 520px;
	}
	.consulta__featured :global(img) {
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		border-radius: var(--theme-shape-radius);
	}

	.consulta__photos {
		margin-top: var(--s2, 1rem);
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--s2, 1rem);
	}
	.consulta__photos :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		aspect-ratio: 4 / 3;
		border-radius: var(--theme-shape-radius);
	}
	.consulta__photos :global(.consulta__photo--tall) {
		object-position: center 56%;
	}

	.consulta__cta {
		margin-top: var(--s4, 2rem);
		padding: clamp(1.75rem, 4vw, 3rem) 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--s2, 1rem);
		background: var(--theme-surface-1, #f2f2f2);
		border-radius: var(--theme-shape-radius);
	}
	.consulta__cta-text {
		margin: 0;
		max-width: 40ch;
		font-size: var(--font-size-lg, 1.25rem);
		font-weight: 600;
		line-height: 1.3;
	}
	.consulta__cta :global(.btn) {
		padding: 0.72rem 1.7rem;
		font-size: 1rem;
		min-height: 44px;
	}

	@media (max-width: 640px) {
		.consulta__photos {
			grid-template-columns: 1fr;
		}
	}
</style>
