PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
PUBLIC_CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

PUBLIC_BOOKING_API_URL=http://localhost:4000
BOOKING_API_URL=http://localhost:4000
APP_ENV=development
PORT=4000
JDBC_URL=jdbc:postgresql://localhost:5432/laguntza_booking?user=booking_app&password=booking_app
POSTGRES_PASSWORD=change-this-database-password
PUBLIC_SITE_URL=http://localhost:4323
BOOKING_SESSION_SECRET=change-this-long-random-secret
BOOKING_ADMIN_EMAIL=info@laguntzafisioterapia.com
BOOKING_ADMIN_PASSWORD_HASH=pbkdf2$210000$...
BOOKING_STAFF_NAME=Laguntza Fisioterapia
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Any SMTP provider works. Two tested options:
# Resend:    SMTP_HOST=smtp.resend.com  SMTP_USER=resend  SMTP_PASS=re_xxx
# Zoho (EU): SMTP_HOST=smtp.zoho.eu     SMTP_USER=info@laguntzafisioterapia.com
#            SMTP_PASS=<app-specific password>
# SMTP_FROM must be an address on a domain verified with the provider.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=...
SMTP_FROM=info@laguntzafisioterapia.com
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
